{
  "name": "primitiv",
  "version": "1.0.7",
  "description": "Spec Driven Development engine for AI-assisted software development",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "primitiv": "dist/bin/primitiv.js"
  },
  "homepage": "https://github.com/primitiv-ai/primitiv#readme",
  "bugs": {
    "url": "https://github.com/primitiv-ai/primitiv/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/primitiv-ai/primitiv.git"
  },
  "scripts": {
    "build": "tsc",
    "build:publish": "node esbuild.config.js",
    "build:viewer": "cd apps/viewer && npm run build && node scripts/copy-standalone.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build:publish"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "keywords": [
    "spec-driven-development",
    "sdd",
    "ai",
    "claude",
    "codex",
    "specifications",
    "cli",
    "bdd",
    "developer-tools",
    "governance"
  ],
  "author": "Primitiv",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "open": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.15.0",
    "memfs": "^4.14.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
